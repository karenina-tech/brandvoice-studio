# ── Next.js ───────────────────────────────────────────────────────────────────
# Node environment: development | production | test
# Next.js sets this automatically via `next dev` / `next build`.
# Only override here if your deploy platform doesn't set it.
NODE_ENV=development

# ── Path B: Managed Credits — server-side master AI keys ──────────────────────
# These are used when a user has NO custom API key (Plan de Créditos path).
# CRITICAL: These values are NEVER sent to the client, NEVER logged, and
# NEVER returned in any HTTP response. They exist only in the server runtime.
#
# Choose one provider and set the matching key:
MASTER_AI_PROVIDER=google        # google | openai | anthropic
MASTER_AI_API_KEY=               # AIza... | sk-... | sk-ant-...

# ── Path A: BYOK — user-supplied keys ─────────────────────────────────────────
# API keys for Path A are entered by the user in the Settings UI and kept
# exclusively in the user's browser localStorage under:
#   ai_provider  →  google | openai | anthropic
#   ai_api_key   →  the raw key string
#   ai_mode      →  byok | managed
#
# They are sent per-request via X-AI-Provider / X-AI-Api-Key headers.
# They are NEVER written here, NEVER stored server-side, NEVER logged.
