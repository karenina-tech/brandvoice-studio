# ── Backend (.env in /backend) ────────────────────────────────────────────────
# Port the Express server listens on
PORT=3001

# Comma-separated list of allowed CORS origins (your deployed frontend URL)
CORS_ORIGIN=http://localhost:5173

# Node environment: development | production | test
NODE_ENV=development

# ── Frontend (.env in /frontend) ──────────────────────────────────────────────
# Absolute URL of the backend API (leave empty to use the Vite dev proxy)
VITE_API_BASE_URL=

# ── BYOK — Never stored server-side ───────────────────────────────────────────
# The Gemini API key is entered by the user via the Settings UI and kept
# exclusively in the user's browser localStorage. It is never written here.
